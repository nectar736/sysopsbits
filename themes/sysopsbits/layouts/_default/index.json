{{- $pages := where .Site.RegularPages "Type" "in" (slice "posts" "tutorials" "comparisons" "reviews" "tools") -}}
{{- $limit := .Site.Config.Services.RSS.Limit -}}
{{- ge $limit 1 -}}
{{- $pages = $pages | first $limit -}}
{
  "title": "{{ .Site.Title }}",
  "description": "{{ .Site.Params.description }}",
  "baseURL": "{{ .Site.BaseURL }}",
  "language": "{{ .Site.LanguageCode }}",
  "author": "{{ .Site.Params.author }}",
  "items": [
    {{- range $i, $p := $pages -}}
    {{- if $i }},{{ end }}
    {
      "title": "{{ $p.Title }}",
      "url": "{{ $p.Permalink }}",
      "date": "{{ $p.Date.Format "2006-01-02T15:04:05Z07:00" }}",
      "categories": [
        {{- range $j, $c := $p.Params.categories -}}
        {{- if $j }},{{ end }}"{{ $c }}"{{- end }}
      ],
      "tags": [
        {{- range $j, $t := $p.Params.tags -}}
        {{- if $j }},{{ end }}"{{ $t }}"{{- end }}
      ],
      "description": "{{ $p.Description }}",
      "content": "{{ $p.Summary | html }}"
    }
    {{- end }}
  ]
}